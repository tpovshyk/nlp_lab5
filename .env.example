# LLM Provider Keys
# Choose ONE: Anthropic (recommended), OpenAI, or Google
ANTHROPIC_API_KEY=sk-ant-...  # From https://console.anthropic.com/
# OPENAI_API_KEY=sk-...         # From https://platform.openai.com/
# GOOGLE_API_KEY=...            # From https://ai.google.dev/

# Telegram Bot (for interactive demo)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE  # From @BotFather on Telegram
TELEGRAM_USER_ID=123456789              # Your Telegram user ID (optional, for restricting access)

# Optional: LangSmith tracing for observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai340-track-a-research-agent

# Model Configuration
# For Anthropic: claude-3-5-sonnet-20241022 (recommended), claude-3-opus-20240229
MODEL_NAME=claude-3-5-sonnet-20241022
# For OpenAI: gpt-4-turbo, gpt-4o
# MODEL_NAME=gpt-4-turbo

# MCP Server cache directory (optional)
MCP_CACHE_DIR=.cache/mcp_cache

